{
  "name": "form-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-first scan-to-fillable-pdf pipeline",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:dev": "docker compose up web",
    "docker:build": "docker compose run --rm workspace pnpm -w build",
    "docker:test": "docker compose run --rm workspace pnpm -w test",
    "docker:lint": "docker compose run --rm workspace pnpm -w lint",
    "docker:typecheck": "docker compose run --rm workspace pnpm -w typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.1",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3"
  }
}
