# Web app Gemini configuration (used by apps/web)
# Copy to `.env` (or `.env.local`) before running the web app locally.

VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model (default in code is gemini-2.5-flash-lite)
VITE_GEMINI_MODEL=gemini-2.5-flash-lite
# Optional confidence cutoff for Gemini answers (default: 0.4)
VITE_GEMINI_CONFIDENCE_THRESHOLD=0.4
